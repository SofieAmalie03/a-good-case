---
const {
  title,
  price,
  oldPrice,
  image,
  hoverImage,
  href,
  badge1 = "6 stk.",
  badge2 = "SPAR 71 DKK",
  badge3 = "",
  bestBefore = "30/11-2026"
} = Astro.props;
---

<a href={href} class="product-card">
  <div class="product-card__top">
    <div class="product-card__actions">
      <span class="product-card__qty">{badge1}</span>
      <span class="product-card__cart">LÆG I KURV</span>
    </div>

    <div class="product-card__badges">
      <span class="product-card__badge">{badge2}</span>
      {badge3 && <span class="product-card__badge">{badge3}</span>}
    </div>

    <div class="product-card__image-wrap">
      <img
        src={image}
        alt={title}
        class="product-card__image product-card__image--default"
      />

      <img
        src={hoverImage || image}
        alt={title}
        class="product-card__image product-card__image--hover"
      />
    </div>
  </div>

  <div class="product-card__info">
    <p class="product-card__date">BEST BEFORE {bestBefore}</p>
    <h3>{title}</h3>

    <div class="product-card__prices">
      <span class="product-card__price">{price}</span>
      {oldPrice && <span class="product-card__old-price">{oldPrice}</span>}
    </div>
  </div>
</a>