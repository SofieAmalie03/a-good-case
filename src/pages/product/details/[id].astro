      "En klassisk west coast IPA med tør finish, tydelig bitterhed og frisk humleprofil. Et sikkert valg til IPA-fans.",
    badge1: "SPAR 71 DKK",
    badge2: "WEST COAST IPA"
  },

  "browar-1": {
    title: "BROWAR STU MOSTOW - 7,3%",
    subtitle: "WCIPA · 6 STK.",
    price: "46,50 DKK",
    oldPrice: "60,00 DKK",
    image: "https://images.unsplash.com/photo-1608270586620-248524c67de9?auto=format&fit=crop&w=900&q=80",
    description:
      "En kraftigere IPA med masser af dybde og humlearoma. Fyldig, bitter og balanceret.",
    badge1: "SPAR 71 DKK",
    badge2: "WCIPA"
  },

  "browar-2": {
    title: "BROWAR STU MOSTOW - 7,3%",
    subtitle: "WCIPA · 6 STK.",
    price: "46,50 DKK",
    oldPrice: "60,00 DKK",
    image: "https://images.unsplash.com/photo-1621939514649-280e2ee25f60?auto=format&fit=crop&w=900&q=80",
    description:
      "Frisk, aromatisk og fyldt med karakter. En øl der passer godt til både mad og hyggelige aftener.",
    badge1: "SPAR 71 DKK",
    badge2: "WCIPA"
  },

  "browar-3": {
    title: "BROWAR STU MOSTOW - 7,3%",
    subtitle: "LAGER · 6 STK.",
    price: "46,50 DKK",
    oldPrice: "60,00 DKK",
    image: "https://images.unsplash.com/photo-1516458464372-ee7eae24b460?auto=format&fit=crop&w=900&q=80",
    description:
      "En sprød lager med ren smag og høj drinkability. Et mere let og klassisk valg.",
    badge1: "SPAR 71 DKK",
    badge2: "LAGER"
  },

  "browar-4": {
    title: "BROWAR STU MOSTOW - 7,3%",
    subtitle: "WCIPA · 6 STK.",
    price: "46,50 DKK",
    oldPrice: "60,00 DKK",
    image: "https://images.unsplash.com/photo-1584225064785-c62a8b43d148?auto=format&fit=crop&w=900&q=80",
    description:
      "En karakterfuld IPA med tydelige humlenoter og tør afslutning. Perfekt til dig der elsker bitterhed og friskhed.",
    badge1: "SPAR 71 DKK",
    badge2: "WCIPA"
  }
};

const { id } = Astro.params;
const product = productContent[id as keyof typeof productContent];
---

<Layout>
  <section class="product-page">
    <div class="product-page__grid">
      <div class="product-page__image-box">
        <img src={product.image} alt={product.title} class="product-page__image" />
      </div>

      <div class="product-page__info">
        <div class="product-page__badges">
          <span class="product-page__badge">{product.badge1}</span>
          <span class="product-page__badge dark">{product.badge2}</span>
        </div>

        <p class="product-page__eyebrow">BEST BEFORE 30/11-2026</p>
        <h1 class="product-page__title">{product.title}</h1>
        <p class="product-page__subtitle">{product.subtitle}</p>

        <div class="product-page__prices">
          <span class="product-page__price">{product.price}</span>
          <span class="product-page__old-price">{product.oldPrice}</span>
        </div>

        <div class="product-page__actions">
          <div class="qty-box">
            <button>-</button>
            <span>1</span>
            <button>+</button>
          </div>

          <button class="buy-btn">LÆG I KURV</button>
        </div>

        <div class="product-page__description">
          <h2>Produktbeskrivelse</h2>
          <p>{product.description}</p>
        </div>
      </div>
    </div>
  </section>
</Layout>