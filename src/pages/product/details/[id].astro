    description:
      "En fyldig og juicy New England IPA med tropiske noter og blød mundfølelse. Masser af aroma og en rund, lækker finish.",
    badge1: "SPAR 71 DKK",
    badge2: "NEW ENGLAND IPA"
  },

  "brewskeeters-ghost": {
    title: "BREWSKEETERS X GHOST BREWING - 6,5%",
    subtitle: "WEST COAST IPA · 6 STK.",
    price: "46,50 DKK",
    oldPrice: "60,00 DKK",
    image: "https://images.unsplash.com/photo-1571767454098-246b94fbcf70?auto=format&fit=crop&w=900&q=80",
