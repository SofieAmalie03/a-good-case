---
import Layout from "../../../layouts/Layout.astro";

export function getStaticPaths() {
  return [
    { params: { id: "aben-birch" } },
    { params: { id: "apex-death-grip-ipa" } },
    { params: { id: "browar-stu-mostow" } },
    { params: { id: "brewskeeters-ghost" } },
    { params: { id: "browar-1" } },
    { params: { id: "browar-2" } },
    { params: { id: "browar-3" } },
    { params: { id: "browar-4" } }
  ];
}

