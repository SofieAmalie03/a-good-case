    badge1: "SPAR 71 DKK",
    badge2: "GLUTENFRI"
  },

  "apex-death-grip-ipa": {
    title: "APEX - DEATH GRIP IPA - 7,7%",
    subtitle: "IPA · 6 STK.",
    price: "33,16 DKK",
    oldPrice: "45,00 DKK",
    image: "https://images.unsplash.com/photo-1584225064785-c62a8b43d148?auto=format&fit=crop&w=900&q=80",
    description:
      "En intens IPA med masser af humle, frugtige noter og markant bitterhed. Death Grip IPA er til dig, der gerne vil have en kraftigere smagsoplevelse.",
    badge1: "SPAR 71 DKK",
    badge2: "WCIPA"
  },

