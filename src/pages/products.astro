---

<Layout>
  <section class="products-section">
    <div class="products-page-header">
      <h1>ALLE VORES ØL</h1>
      <p>
        Red god kvalitetsøl fra landets bedste bryggerier og spar op til 40%.
        <br />
        Se udvalget og find dine favoritter
      </p>
    </div>

    <div class="products-toolbar">
      <button class="filter-btn">FILTER OG SORTÉR</button>
    </div>

    <div class="products-grid">
      {products.map((product) => (
        <ProductCard
          title={product.title}
          price={product.price}
          oldPrice={product.oldPrice}
          image={product.image}
          href={`/product/${product.id}`}
          badge1={product.badge1}
          badge2={product.badge2}
          badge3={product.badge3}
        />
      ))}
    </div>
  </section>
</Layout>