---
import Layout from "../layouts/Layout.astro";
import ProductCard from "../components/ProductCard.astro";

const endpoint = "https://dkcobhfkefcqzibaskdu.supabase.co/rest/v1/produkter?select=*";
const key = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRrY29iaGZrZWZjcXppYmFza2R1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY0MDM2MjksImV4cCI6MjA5MTk3OTYyOX0.OpaFaejAvrmWvAEZjmJYbM8g7b6GUC_6SEZgiDfcqNk";

const res = await fetch(endpoint, {
  headers: {
    apikey: key,
    Authorization: `Bearer ${key}`,
  },
});

const products = await res.json();

type Product = {
  id: number;
  name?: string;
  price?: number;
  old_price?: number;
  discount_text?: string;
  quantity_default?: number;
  best_before?: string;
  image_url?: string;
  hover_image_url?: string;
  type?: string;
  style?: string;
};

const cleanText = (value: unknown) =>
  String(value ?? "")
    .replace(/\n/g, " ")
    .replace(/\s+/g, " ")
    .trim();

const formatPrice = (value: unknown) => {
  const num = Number(value);
  if (Number.isNaN(num)) return "";
  return `Fra ${num.toFixed(2).replace(".", ",")} DKK`;
};

const formatOldPrice = (value: unknown) => {
  const num = Number(value);
  if (Number.isNaN(num)) return "";
  return `${num.toFixed(2).replace(".", ",")} DKK`;
};

const formatDate = (value: unknown) => {
  const raw = String(value ?? "").trim();
  if (!raw) return "30/11-2026";
  const [year, month, day] = raw.split("-");
  if (!year || !month || !day) return raw;
  return `${day}/${month}-${year}`;
};
---

<Layout>
  <section class="productlist-page">
    <div class="productlist-header">
      <h1>ALLE VORES ØL</h1>
      <p>
        Red god kvalitetsøl fra landets bedste bryggerier og spar op til 40%.
        <br />
        Se udvalget og find dine favoritter
      </p>
    </div>

    <div class="productlist-toolbar">
      <button type="button" class="filter-btn">FILTER OG SORTÉR</button>
    </div>

    <div class="productlist-grid">
      {products.map((product: Product) => (
        <ProductCard
          href={`/details/${product.id}`}
          title={cleanText(product.name)}
          price={formatPrice(product.price)}
          oldPrice={formatOldPrice(product.old_price)}
          image={cleanText(product.image_url)}
          hoverImage={cleanText(product.hover_image_url || product.image_url)}
          badge1={`${product.quantity_default ?? 6} stk.`}
          badge2={cleanText(product.discount_text || "SPAR 71 DKK")}
          badge3={cleanText(product.style || product.type)}
          bestBefore={formatDate(product.best_before)}
        />
      ))}
    </div>
  </section>
</Layout>