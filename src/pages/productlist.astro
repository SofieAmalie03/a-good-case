---
import Layout from "../layouts/Layout.astro";

const endpoint = "https://dkcobhfkefcqzibaskdu.supabase.co/rest/v1/produkter?select=*";
const key = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRrY29iaGZrZWZjcXppYmFza2R1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY0MDM2MjksImV4cCI6MjA5MTk3OTYyOX0.OpaFaejAvrmWvAEZjmJYbM8g7b6GUC_6SEZgiDfcqNk";

const res = await fetch(endpoint, {
  headers: {
    apikey: key,
    Authorization: `Bearer ${key}`,
  },
});

const products = await res.json();

type Product = {
  id?: number;
  name?: string;
  price?: number;
  old_price?: number;
  discount_text?: string;
  quantity_default?: number;
  best_before?: string;
  image_url?: string;
  hover_image_url?: string;
  type?: string;
  style?: string;
  slug?: string;
};

const cleanText = (value: unknown) =>
  String(value ?? "")
    .replace(/\n/g, " ")
    .replace(/\s+/g, " ")
    .trim();

const formatPrice = (value: unknown) => {
  const num = Number(value);
  if (Number.isNaN(num)) return "";
  return `Fra ${num.toFixed(2).replace(".", ",")} DKK`;
};

const formatOldPrice = (value: unknown) => {
  const num = Number(value);
  if (Number.isNaN(num)) return "";
  return `${num.toFixed(2).replace(".", ",")} DKK`;
};

const formatDate = (value: unknown) => {
  const raw = String(value ?? "").trim();
  if (!raw) return "";
  const [year, month, day] = raw.split("-");
  if (!year || !month || !day) return raw;
  return `${day}/${month}-${year}`;
};

const makeSlug = (product: Product) => {
  const raw = cleanText(product.slug || product.name || "");
  return raw
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9\s-]/g, "")
    .trim()
    .replace(/\s+/g, "-");
};
---

<Layout>
  <section class="productlist-page">
    <div class="productlist-header">
      <h1>ALLE VORES ØL</h1>
      <p>
        Red god kvalitetsøl fra landets bedste bryggerier og spar op til 40%.
        <br />
        Se udvalget og find dine favoritter
      </p>
    </div>

    <div class="productlist-toolbar">
      <button type="button" class="filter-btn">FILTER OG SORTÉR</button>
    </div>

    <div class="beer-grid">
      {products.map((product: Product) => {
        const slug = makeSlug(product);
        const image = cleanText(product.image_url);
        const hoverImage = cleanText(product.hover_image_url || product.image_url);
        const title = cleanText(product.name);
        const badge = cleanText(product.style || product.type);
        const discount = cleanText(product.discount_text || "SPAR 71 DKK");
        const quantity = product.quantity_default ?? 6;

        return (
          <a href={`/product/${slug}`} class="beer-card">
            <div class="beer-card__top">
              <div class="beer-card__actions">
                <span class="beer-card__qty">{quantity} stk.</span>
                <span class="beer-card__cart">LÆG I KURV</span>
              </div>

              <div class="beer-card__badges">
                <span class="beer-card__badge">{discount}</span>
                {badge && <span class="beer-card__badge">{badge}</span>}
              </div>

              <div class="beer-card__image-wrap">
                <img
                  src={image}
                  alt={title}
                  class="beer-card__image beer-card__image--default"
                />
                <img
                  src={hoverImage}
                  alt={title}
                  class="beer-card__image beer-card__image--hover"
                />
              </div>
            </div>

            <div class="beer-card__info">
              <p class="beer-card__date">BEST BEFORE {formatDate(product.best_before)}</p>
              <h3>{title}</h3>

              <div class="beer-card__prices">
                <span class="beer-card__price">{formatPrice(product.price)}</span>
                <span class="beer-card__old-price">{formatOldPrice(product.old_price)}</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>

<style>
  .productlist-page {
    max-width: 1220px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
    color: #1e1a17;
  }

  .productlist-header {
    text-align: center;
    margin: 1.2rem 0 2rem;
  }

  .productlist-header h1 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 500;
    letter-spacing: 0.02em;
    margin: 0 0 0.75rem;
  }

  .productlist-header p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #4b443d;
  }

  .productlist-toolbar {
    margin-bottom: 1.5rem;
  }

  .filter-btn {
    background: #f3efe9;
    border: 1px solid #d7cfc3;
    color: #4f453b;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    padding: 0.9rem 1rem;
    cursor: pointer;
  }

  .beer-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .beer-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .beer-card__top {
    position: relative;
    min-height: 340px;
    padding-top: 2.1rem;
  }

  .beer-card__actions {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    gap: 0.45rem;
    align-items: center;
    z-index: 3;
  }

  .beer-card__qty,
  .beer-card__cart {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .beer-card__qty {
    min-width: 3.5rem;
    padding: 0 0.7rem;
    background: white;
    border: 1px solid #d8d0c5;
  }

  .beer-card__cart {
    min-width: 8rem;
    padding: 0 0.9rem;
    background: #b6a383;
    color: white;
  }

  .beer-card__badges {
    position: absolute;
    top: 2.45rem;
    left: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    z-index: 3;
  }

  .beer-card__badge {
    display: inline-flex;
    align-items: center;
    width: max-content;
    min-height: 1.1rem;
    padding: 0.1rem 0.45rem;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: white;
    background: #5c4035;
    text-transform: uppercase;
  }

  .beer-card__image-wrap {
    position: relative;
    height: 290px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    overflow: hidden;
  }

  .beer-card__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity 0.25s ease;
  }

  .beer-card__image--hover {
    opacity: 0;
  }

  .beer-card:hover .beer-card__image--hover {
    opacity: 1;
  }

  .beer-card:hover .beer-card__image--default {
    opacity: 0;
  }

  .beer-card__info {
    background: #f4efe8;
    border: 1px solid #ddd3c6;
    border-radius: 6px;
    padding: 1.2rem 1rem 1rem;
    min-height: 150px;
  }

  .beer-card__date {
    text-align: center;
    font-size: 0.68rem;
    color: #4f453b;
    margin: 0 0 1rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .beer-card__info h3 {
    margin: 0 0 1.1rem;
    text-align: center;
    font-size: 1rem;
    line-height: 1.35;
    font-weight: 700;
    text-transform: uppercase;
    min-height: 2.8em;
  }

  .beer-card__prices {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
    font-size: 0.9rem;
  }

  .beer-card__price {
    color: #b49b71;
  }

  .beer-card__old-price {
    color: #9b8d7e;
    text-decoration: line-through;
  }

  @media (max-width: 1100px) {
    .beer-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 780px) {
    .beer-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .beer-card__top {
      min-height: 300px;
    }

    .beer-card__image-wrap {
      height: 250px;
    }
  }

  @media (max-width: 520px) {
    .productlist-page {
      padding: 1.5rem 1rem 3rem;
    }

    .beer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 0.8rem;
    }

    .beer-card__top {
      min-height: 240px;
      padding-top: 1.8rem;
    }

    .beer-card__actions {
      gap: 0.3rem;
    }

    .beer-card__qty {
      min-width: 2.8rem;
      font-size: 0.55rem;
      height: 1.4rem;
      padding: 0 0.35rem;
    }

    .beer-card__cart {
      min-width: 5.2rem;
      font-size: 0.55rem;
      height: 1.4rem;
      padding: 0 0.45rem;
    }

    .beer-card__badges {
      top: 1.85rem;
    }

    .beer-card__badge {
      font-size: 0.45rem;
      min-height: 0.95rem;
      padding: 0.08rem 0.3rem;
    }

    .beer-card__image-wrap {
      height: 190px;
    }

    .beer-card__info {
      padding: 0.8rem 0.55rem 0.7rem;
      min-height: 115px;
    }

    .beer-card__date {
      font-size: 0.5rem;
      margin-bottom: 0.6rem;
    }

    .beer-card__info h3 {
      font-size: 0.7rem;
      margin-bottom: 0.75rem;
      min-height: 2.6em;
    }

    .beer-card__prices {
      gap: 0.35rem;
      font-size: 0.62rem;
    }

    .filter-btn {
      font-size: 0.62rem;
      padding: 0.65rem 0.75rem;
    }

    .productlist-header p {
      font-size: 0.75rem;
    }
  }
</style>