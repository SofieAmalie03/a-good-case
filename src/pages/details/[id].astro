---
import Layout from "../../layouts/Layout.astro";

type Product = {
  id: number;
  name?: string;
  price?: number;
  old_price?: number;
  image_url?: string;
  hover_image_url?: string;
  best_before?: string;
  style?: string;
  type?: string;
  description?: string;
  quantity_default?: number;
};

const cleanText = (value: unknown) =>
  String(value ?? "")
    .replace(/\n/g, " ")
    .replace(/\s+/g, " ")
    .trim();

const formatPrice = (value: unknown) => {
  const num = Number(value);
  if (Number.isNaN(num)) return "";
  return `${num.toFixed(2).replace(".", ",")} DKK`;
};

export async function getStaticPaths() {
  const endpoint =
    "https://dkcobhfkefcqzibaskdu.supabase.co/rest/v1/produkter?select=*";

  const key =
    "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRrY29iaGZrZWZjcXppYmFza2R1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY0MDM2MjksImV4cCI6MjA5MTk3OTYyOX0.OpaFaejAvrmWvAEZjmJYbM8g7b6GUC_6SEZgiDfcqNk";

  const response = await fetch(endpoint, {
    headers: {
      apikey: key,
      Authorization: `Bearer ${key}`,
    },
  });

  const data: Product[] = await response.json();

  return data.map((product) => ({
    params: { id: product.id.toString() },
    props: { product },
  }));
}

const { product } = Astro.props as { product: Product };

const relatedCategories = [
  { title: "VORES MØRKE", image: "/img/dark-beer.png" },
  { title: "LAGER/PILSER", image: "/img/lager-beer.png" },
  { title: "VORES LYSE", image: "/img/light-beer.png" },
  { title: "VORES SYRLIGE", image: "/img/sour-beer.png" },
];
---

<Layout>
  <section class="detail-page">
    <div class="detail-page__top">
      <div class="detail-page__image-col">
        <div class="detail-product-image">
          <img
            src={cleanText(product.image_url)}
            alt={cleanText(product.name)}
          />
        </div>
      </div>

      <div class="detail-page__spec-col">
        <div class="detail-specs">
          <div class="detail-specs__head">INFORMATIONS KORT</div>

          <div class="detail-specs__row">
            <span>ABV</span>
            <span>7,5%</span>
          </div>

          <div class="detail-specs__row">
            <span>IBU</span>
            <span>60</span>
          </div>

          <div class="detail-specs__row">
            <span>STYLE</span>
            <span>{cleanText(product.style || product.type || "ØL")}</span>
          </div>
        </div>
      </div>

      <div class="detail-page__content-col">
        <p class="detail-main__eyebrow">
          {cleanText(product.style || product.type || "SPECIALØL")}
        </p>

        <h1 class="detail-main__title">{cleanText(product.name)}</h1>

        <div class="detail-main__underline"></div>

        <div class="detail-buy-box">
          <div class="detail-buy-box__row">
            <strong>1 stk.</strong>
            <span>{formatPrice(product.price)}</span>
            {product.old_price && (
              <span class="detail-buy-box__old">Vejl. pris {formatPrice(product.old_price)}</span>
            )}
          </div>

          <div class="detail-buy-box__row detail-buy-box__row--active">
            <strong>6 stk.</strong>
            <span>35,00 DKK stk</span>
            <span>210,00 DKK TOTALT</span>
          </div>

          <div class="detail-qty">
            <button type="button">−</button>
            <span>1</span>
            <button type="button">+</button>
          </div>

          <button class="detail-buy-btn">LÆG I KURV</button>

          <div class="detail-payments">
            <span>💳</span>
            <span>🪪</span>
            <span>💳</span>
            <span>🟠</span>
          </div>
        </div>
      </div>
    </div>

    <div class="detail-description">
      <p><strong>Untappd rating: 3.7</strong></p>
      <p>
        {cleanText(
          product.description ||
            "Death Grip IPA fra Apex er en 7,5% West Coast IPA, der holder fast i din opmærksomhed med sin dybde og fylde."
        )}
      </p>
      <p>
        Denne IPA har en maltbase med Pale Ale-, Munich- og lys karamellmalt, som tilføjer både krop og et strejf af sødme. Columbus og Simcoe-humlerne i brygningen giver en solid bitterhed, mens den kraftige tørhumling med Strata og Citra tilfører friske noter af tropiske frugter og citrus.
      </p>
      <p>
        En IPA, der balancerer mellem sødme og bitterhed, med en fyldig, humledrevet profil, som leverer en intens smagsoplevelse fra første tår til sidste.
      </p>
    </div>

    <section class="detail-related">
      <p class="detail-related__eyebrow">VÆLG DIN KATEGORI</p>
      <h2>UDFORSK ANDRE ØL</h2>

      <div class="detail-related__grid">
        {relatedCategories.map((item) => (
          <div class="detail-related__card">
            <img src={item.image} alt={item.title} />
            <a href="/productlist">{item.title}</a>
          </div>
        ))}
      </div>

      <div class="detail-related__nav">‹ &nbsp; 1/8 &nbsp; ›</div>
    </section>
  </section>
</Layout>