---
import Layout from "../../layouts/Layout.astro";

type Product = {
  id: number;
  name?: string;
  price?: number;
  old_price?: number;
  image_url?: string;
  hover_image_url?: string;
  best_before?: string;
  style?: string;
  type?: string;
  description?: string;
  quantity_default?: number;
  abv?: number;
  ABV?: number;
  ibu?: number;
};

const cleanText = (value: unknown) =>
  String(value ?? "")
    .replace(/\n/g, " ")
    .replace(/\s+/g, " ")
    .trim();

const formatPrice = (value: unknown) => {
  const num = Number(value);
  if (Number.isNaN(num)) return "";
  return `${num.toFixed(2).replace(".", ",")} DKK`;
};

const formatPercent = (value: unknown) => {
  const num = Number(value);
  if (Number.isNaN(num)) return "";
  return `${num.toFixed(1).replace(".", ",")}%`;
};

export async function getStaticPaths() {
  const endpoint =
    "https://dkcobhfkefcqzibaskdu.supabase.co/rest/v1/produkter?select=*";

  const key =
    "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRrY29iaGZrZWZjcXppYmFza2R1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY0MDM2MjksImV4cCI6MjA5MTk3OTYyOX0.OpaFaejAvrmWvAEZjmJYbM8g7b6GUC_6SEZgiDfcqNk";

  const response = await fetch(endpoint, {
    headers: {
      apikey: key,
      Authorization: `Bearer ${key}`,
    },
  });

  const data: Product[] = await response.json();

  return data.map((product) => ({
    params: { id: product.id.toString() },
    props: { product },
  }));
}

const { product } = Astro.props as { product: Product };

const relatedCategories = [
  { title: "VORES MØRKE", image: "/moerke.png" },
  { title: "LAGER/PILSNER", image: "/lager-pilsner.png" },
  { title: "VORES LYSE", image: "/lyse.png" },
  { title: "VORES SYRLIGE", image: "/syrlige.png" },
];

const styleLabel = cleanText(product.style || product.type || "SPECIALØL");
const abvValue = product.abv ?? product.ABV ?? 7.5;
const ibuValue = product.ibu ?? 60;

const singlePrice = Number(product.price ?? 0);
const packSize = 6;
const packUnitPrice = 35;
const packTotalPrice = packSize * packUnitPrice;
---

<Layout>
  <section class="detail-page">
    <div class="detail-page__top">
      <div class="detail-page__image-col">
        <div class="detail-product-image">
          <img
            src={cleanText(product.image_url)}
            alt={cleanText(product.name)}
          />
        </div>

        <div class="detail-specs">
          <div class="detail-specs__head">INFORMATIONS KORT</div>

          <div class="detail-specs__row">
            <span>ABV</span>
            <span>{formatPercent(abvValue)}</span>
          </div>

          <div class="detail-specs__row">
            <span>IBU</span>
            <span>{ibuValue}</span>
          </div>

          <div class="detail-specs__row">
            <span>STYLE</span>
            <span>{styleLabel}</span>
          </div>
        </div>
      </div>

      <div class="detail-page__content-col">
        <p class="detail-main__eyebrow">{styleLabel}</p>

        <h1 class="detail-main__title">{cleanText(product.name)}</h1>

        <div class="detail-main__underline"></div>

        <div
          class="detail-buy-box"
          data-product-id={product.id}
          data-product-name={cleanText(product.name)}
          data-product-image={cleanText(product.image_url)}
          data-single-price={singlePrice}
          data-pack-size={packSize}
          data-pack-unit-price={packUnitPrice}
        >
<button
  type="button"
  class="detail-buy-box__row detail-buy-option"
  data-pack="1"
>
  <strong>1 stk.</strong>
  <span>{formatPrice(product.price)}</span>
  {product.old_price && (
    <span class="detail-buy-box__old">
      Vejl. pris {formatPrice(product.old_price)}
    </span>
  )}
</button>

<button
  type="button"
  class="detail-buy-box__row detail-buy-option is-active"
  data-pack={packSize}
>
  <strong>{packSize} stk.</strong>
  <span>{packUnitPrice.toFixed(2).replace(".", ",")} DKK stk</span>
  <span>{packTotalPrice.toFixed(2).replace(".", ",")} DKK TOTALT</span>
</button>

<div class="detail-qty">
  <button type="button" class="detail-qty__btn" data-action="minus">−</button>
  <span class="detail-qty__value" data-qty>1</span>
  <button type="button" class="detail-qty__btn" data-action="plus">+</button>
</div>

          <button class="detail-buy-btn" type="button" data-add-to-cart>
            LÆG I KURV
          </button>

          <div class="detail-payments">
            <span>💳</span>
            <span>🪪</span>
            <span>💳</span>
            <span>🟠</span>
          </div>
        </div>
      </div>
    </div>

    <div class="detail-description">
      <p><strong>Untappd rating: 3.7</strong></p>
      <p>
        {cleanText(
          product.description ||
            "Death Grip IPA fra Apex er en 7,5% West Coast IPA, der holder fast i din opmærksomhed med sin dybde og fylde."
        )}
      </p>
      <p>
        Denne IPA har en maltbase med Pale Ale-, Munich- og lys karamellmalt,
        som tilføjer både krop og et strejf af sødme. Columbus og
        Simcoe-humlerne i brygningen giver en solid bitterhed, mens den kraftige
        tørhumling med Strata og Citra tilfører friske noter af tropiske
        frugter og citrus.
      </p>
      <p>
        En IPA, der balancerer mellem sødme og bitterhed, med en fyldig,
        humledrevet profil, som leverer en intens smagsoplevelse fra første tår
        til sidste.
      </p>
    </div>

    <section class="detail-related">
      <p class="detail-related__eyebrow">VÆLG DIN KATEGORI</p>
      <h2>UDFORSK ANDRE ØL</h2>

      <div class="detail-related__grid">
        {relatedCategories.map((item) => (
          <div class="detail-related__card">
            <img src={item.image} alt={item.title} />
            <a href="/productlist">{item.title}</a>
          </div>
        ))}
      </div>

      <div class="detail-related__nav">‹ &nbsp; 1/8 &nbsp; ›</div>
    </section>
  </section>
</Layout>

<script>
  const buyBox = document.querySelector(".detail-buy-box");
  if (buyBox) {
    const optionButtons = buyBox.querySelectorAll(".detail-buy-option");
    const qtyValue = buyBox.querySelector("[data-qty]");
    const minusBtn = buyBox.querySelector('[data-action="minus"]');
    const plusBtn = buyBox.querySelector('[data-action="plus"]');
    const addToCartBtn = buyBox.querySelector("[data-add-to-cart]");

    let selectedPack = 6;
    let quantity = 1;

    const updateQtyUI = () => {
      if (qtyValue) qtyValue.textContent = String(quantity);
    };

    optionButtons.forEach((button) => {
      button.addEventListener("click", () => {
        optionButtons.forEach((btn) => btn.classList.remove("is-active"));
        button.classList.add("is-active");
        selectedPack = Number(button.getAttribute("data-pack")) || 1;
      });
    });

    minusBtn?.addEventListener("click", () => {
      if (quantity > 1) {
        quantity -= 1;
        updateQtyUI();
      }
    });

    plusBtn?.addEventListener("click", () => {
      quantity += 1;
      updateQtyUI();
    });

    addToCartBtn?.addEventListener("click", () => {
      const productId = Number(buyBox.getAttribute("data-product-id"));
      const productName = buyBox.getAttribute("data-product-name") || "";
      const productImage = buyBox.getAttribute("data-product-image") || "";
      const singlePrice = Number(buyBox.getAttribute("data-single-price")) || 0;
      const packUnitPrice =
        Number(buyBox.getAttribute("data-pack-unit-price")) || singlePrice;

      const unitPrice = selectedPack === 1 ? singlePrice : packUnitPrice;
      const totalUnits = selectedPack * quantity;

      const cartItem = {
        id: productId,
        name: productName,
        image: productImage,
        packSize: selectedPack,
        quantity,
        totalUnits,
        unitPrice,
      };

      const existingCart = JSON.parse(localStorage.getItem("cart") || "[]");
      const existingIndex = existingCart.findIndex(
        (item: { id: number; packSize: number }) => item.id === cartItem.id && item.packSize === cartItem.packSize
      );

      if (existingIndex > -1) {
        existingCart[existingIndex].quantity += cartItem.quantity;
        existingCart[existingIndex].totalUnits += cartItem.totalUnits;
      } else {
        existingCart.push(cartItem);
      }

      localStorage.setItem("cart", JSON.stringify(existingCart));

      const cartCount = existingCart.reduce(
        (sum: number, item: { totalUnits?: number }) => sum + Number(item.totalUnits || 0),
        0
      );

      localStorage.setItem("cartCount", String(cartCount));
      window.dispatchEvent(new CustomEvent("cart-updated", { detail: { cartCount } }));

      addToCartBtn.textContent = "LAGT I KURV";
      setTimeout(() => {
        addToCartBtn.textContent = "LÆG I KURV";
      }, 1200);
    });

    updateQtyUI();
  }
</script>